rune square(x) { x * x }
rune add(a, b) { a + b }
rune double_it(x) { x + x }
rune cube(x) { x * x * x }
rune sum3(a, b, c) { a + b + c }
rune max(a, b) { if a > b { a } else { b } }
rune min(a, b) { if a < b { a } else { b } }
rune debug(msg, val) { print(msg); print(val); }
rune repeat_print(x) { print(x); print(x); }

fn main(): void {
    print(square!(5));
    print(square!(3));
    print(add!(100, 200));
    print(double_it!(7));
    print(cube!(3));
    print(sum3!(10, 20, 30));

    let x: int = square!(4);
    print(x);

    let y: int = add!(square!(3), 1);
    print(y);

    print(max!(10, 20));
    print(min!(10, 20));

    debug!("count", 42);
    repeat_print!(99);
}
