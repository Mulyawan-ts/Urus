{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Urus",
  "scopeName": "source.urus",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.urus",
          "match": "//.*$"
        },
        {
          "name": "comment.block.urus",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.urus",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "meta.interpolation.urus",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            },
            {
              "name": "constant.character.escape.urus",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.urus",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.urus",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.urus",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.octal.urus",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.urus",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.urus",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.urus",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.urus",
          "match": "\\b(if|else|while|for|in|return|break|continue|match|do|defer|try|catch|await|async)\\b"
        },
        {
          "name": "keyword.declaration.urus",
          "match": "\\b(fn|let|mut|struct|enum|trait|impl|const|import|type|rune|test)\\b"
        },
        {
          "name": "keyword.other.urus",
          "match": "\\b(__emit__)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.urus",
          "match": "\\b(int|float|bool|str|void|Result)\\b"
        },
        {
          "name": "support.type.urus",
          "match": "\\b(Ok|Err)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.urus",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.urus",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.urus",
          "match": "(\\*\\*|%%|&&|\\|\\||==|!=|<=|>=|<<|>>|&~|\\+\\+|--|=>|\\.\\.=?|\\?)"
        }
      ]
    }
  }
}
